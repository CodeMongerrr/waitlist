  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20251121.0",
    "@types/react": "19.0.7",
    "react": "19.0.0",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
