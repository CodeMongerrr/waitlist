{
  "name": "@waitlist-stack/email",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Provider-agnostic transactional email (Resend, Postmark, SendGrid stubs) plus templates and a Svix-verified webhook for the waitlist-stack template.",
  "keywords": ["email", "resend", "svix", "waitlist", "transactional"],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./providers": "./src/providers/index.ts",
    "./templates": "./src/templates/index.ts",
    "./webhook": "./src/webhook/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@waitlist-stack/config": "workspace:*",
    "@waitlist-stack/db": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20251121.0",
    "@types/better-sqlite3": "7.6.12",
    "better-sqlite3": "11.7.0",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
